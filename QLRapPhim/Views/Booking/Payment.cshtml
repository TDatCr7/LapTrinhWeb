@model QLRapPhim.Models.Booking
@{
    ViewData["Title"] = "Thanh toán";
    var seatPositions = ViewBag.SeatPositions as string;
    var totalPrice = ViewBag.TotalPrice as decimal?;
    var quantity = ViewBag.Quantity as int?;
    var bookings = ViewBag.Bookings as List<QLRapPhim.Models.Booking>;
    var totalTicketPrice = ViewBag.TotalTicketPrice as decimal?; // Giá vé tổng
    var totalFoodPrice = ViewBag.TotalFoodPrice as decimal?;    // Giá đồ ăn tổng
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Thông tin thanh toán</h3>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Phim:</strong> @Model.Showtime.Movie.Name</li>
                        <li class="list-group-item"><strong>Ngày chiếu:</strong> @Model.Showtime.ShowDate.ToString("dd/MM/yyyy")</li>
                        <li class="list-group-item"><strong>Giờ chiếu:</strong> @Model.Showtime.StartTime.ToString(@"hh\:mm")</li>
                        <li class="list-group-item"><strong>Phòng:</strong> @Model.Showtime.Screen.Name</li>
                        <li class="list-group-item"><strong>Ghế:</strong> @seatPositions</li>
                        <li class="list-group-item"><strong>Loại vé:</strong> @Model.BookingDetails.First().TicketPrice.Name</li>
                        <li class="list-group-item"><strong>Số lượng:</strong> @quantity</li>
                        @if (Model.Food != null)
                        {
                            <li class="list-group-item"><strong>Đồ ăn:</strong> @Model.Food.Name (Số lượng: @(ViewBag.FoodQuantity ?? 1))</li>
                        }
                        <li class="list-group-item"><strong>Giá vé:</strong> @totalTicketPrice?.ToString("C")</li>
                        <li class="list-group-item"><strong>Giá đồ ăn:</strong> @totalFoodPrice?.ToString("C")</li>
                        <li class="list-group-item"><strong>Tổng tiền:</strong> @totalPrice?.ToString("C")</li>
                    </ul>
                    <form asp-action="CreatePaymentUrl" method="post">
                        <input type="hidden" name="bookingId" value="@Model.Id" />
                        <button type="submit" class="btn btn-success mt-3">Thanh toán qua VNPay</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>