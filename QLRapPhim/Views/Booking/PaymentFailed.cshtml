@model QLRapPhim.Models.Booking
@{
    ViewData["Title"] = "Thanh toán thất bại";
    var seatPositions = ViewBag.SeatPositions as string;
    var error = ViewBag.Error as string;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Thanh toán thất bại</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger" role="alert">
                        @error
                    </div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Phim:</strong> @Model.Showtime.Movie.Name</li>
                        <li class="list-group-item"><strong>Ngày chiếu:</strong> @Model.Showtime.ShowDate.ToString("dd/MM/yyyy")</li>
                        <li class="list-group-item"><strong>Giờ chiếu:</strong> @Model.Showtime.StartTime.ToString(@"hh\:mm")</li>
                        <li class="list-group-item"><strong>Phòng:</strong> @Model.Showtime.Screen.Name</li>
                        <li class="list-group-item"><strong>Ghế:</strong> @seatPositions</li>
                    </ul>
                    <a href="@Url.Action("SelectSeat", "Booking", new { showtimeId = Model.ShowtimeId })" class="btn btn-primary mt-3">Chọn lại ghế</a>
                </div>
            </div>
        </div>
    </div>
</div>